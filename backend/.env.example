# ==========================================
# U-Dash Backend Environment Variables
# ==========================================

# 1. Database Configuration
# - If left empty or commented out, the backend will automatically fallback
#   to a local SQLite database file: sqlite:///dashboard.db (Perfect for local dev!)
# - For Production, paste your Supabase PostgreSQL connection string here:
# DATABASE_URL=postgresql://postgres.your-supabase-db-id:password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# 2. JWT Security Setup
# - Generate a strong secure secret key using: openssl rand -hex 32
JWT_SECRET=super-secret-key-change-this-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=43200  # 30 Days in minutes (to prevent shop owners from being logged out constantly)

# 3. LINE Notify Integration (Setup Only)
# - Generate your developer or client group token from https://notify-bot.line.me/
LINE_NOTIFY_TOKEN=your_line_notify_group_token_here

# 4. CORS Origins Configuration (Production Only)
# - Comma-separated list of allowed frontend origins (e.g., Vercel URL)
# ALLOWED_ORIGINS=https://udash-client.vercel.app,https://your-custom-domain.com
